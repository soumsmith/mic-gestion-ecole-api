	<queryString language="SQL">
		<![CDATA[select distinct `ecoleviedbv2`.ve_bulletin_annuel_primaire.matricule ,
`ecoleviedbv2`.ve_bulletin_annuel_primaire.nom ,
 `ecoleviedbv2`.ve_bulletin_annuel_primaire.prenoms,
  `ecoleviedbv2`.ve_bulletin_annuel_primaire.sexe, 
  `ecoleviedbv2`.ve_bulletin_annuel_primaire.moy_annuelle,
 `ecoleviedbv2`.ve_bulletin_annuel_primaire.rang_annuelle,
`ecoleviedbv2`.ve_bulletin_annuel_primaire.appreciation_conseil,`ecoleviedbv2`.ve_bulletin_annuel_primaire.bg,
`ecoleviedbv2`.ve_bulletin_annuel_primaire.libelle_classe,`ecoleviedbv2`.ve_bulletin_annuel_primaire.annee_libelle
 from  `ecoleviedbv2`.ve_bulletin_annuel_primaire
where 
`ecoleviedbv2`.ve_bulletin_annuel_primaire.id_ecole=  $P{idEcole} and
`ecoleviedbv2`.ve_bulletin_annuel_primaire.annee_libelle= $P{annee} and
`ecoleviedbv2`.ve_bulletin_annuel_primaire.libelle_periode= $P{libellePeriode} and
`ecoleviedbv2`.ve_bulletin_annuel_primaire.libelle_classe=  $P{classe} and `ecoleviedbv2`.ve_bulletin_annuel_primaire.is_arabe=1
   order by `ecoleviedbv2`.ve_bulletin_annuel_primaire.nom , `ecoleviedbv2`.ve_bulletin_annuel_primaire.prenoms]]>
	</queryString>
